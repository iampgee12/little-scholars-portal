# Email setup for published result reports.
# Create email-settings.env beside server.js with these same keys and your real SMTP values.

# Common direct TLS SMTP setup. Many providers use port 465 with secure TLS.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true

# SMTP account used to send the report emails.
SMTP_USER=
SMTP_PASS=

# Sender address shown to parents. If blank, the server falls back to SMTP_USER.
SMTP_FROM=
